# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore build artifacts and non-essential files
bin/
cover.out
dist/
*.md
!go.mod
!go.sum
LICENSE

# Ignore test files
**/*_test.go
test/

# Ignore CI/CD and config
.github/
.devcontainer/
.claude/
.git/
.gitignore
.dockerignore
.golangci.yml
.custom-gcl.yml
.pre-commit-config.yaml

# Ignore Kubernetes manifests (not needed for binary build)
config/

# Ignore unrelated sub-projects
aerospike-cluster-manager/
